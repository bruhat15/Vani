
# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent provider selection
ASR_BACKEND=whisper
LLM_BACKEND=groq
TTS_BACKEND=kokoro

# ASR
WHISPER_MODEL_SIZE=base
INDIC_CONFORMER_MODEL_PATH=./models/indic-conformer

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# TTS
KOKORO_MODEL_PATH=./models/kokoro
INDIC_F5_MODEL_PATH=./models/indic-f5
TTS_VOICE=af_heart
TTS_SAMPLE_RATE=24000

# Supabase (agent)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RAG_TOP_K=5
EMBEDDING_MODEL=nomic-embed-text

# Telemetry
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Health
HEALTH_PORT=8080